## Local environment variables (Vite)
## Copy to `.env.local` and fill in values. Do not commit `.env.local`.

# Gemini / Google Generative Language API key used by the frontend app
# The app also accepts VITE_GEMINI_API_KEY as an alias if you prefer that name.
VITE_GOOGLE_API_KEY=your_api_key_here
VITE_GEMINI_API_KEY=your_api_key_here

# Node.js server / CLI API key used by dotenv in src/services/geminiClient.js
# Copy this file to .env and fill in the real key for Node.js usage.
GOOGLE_API_KEY=your_google_generative_ai_api_key_here

